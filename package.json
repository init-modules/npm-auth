{
	"name": "@init/auth",
	"version": "0.1.0",
	"description": "Auth contracts, runtime state and service factories for init.",
	"type": "module",
	"files": [
		"dist",
		"src"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.js",
			"default": "./dist/server.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.js",
			"default": "./dist/client.js"
		},
		"./nextjs": {
			"types": "./dist/nextjs.d.ts",
			"import": "./dist/nextjs.js",
			"default": "./dist/nextjs.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts src/server.ts src/client.ts src/nextjs.ts --format esm --dts --clean && node scripts/stamp-use-client.mjs",
		"prepack": "npm run build"
	},
	"dependencies": {
		"axios": "^1.13.2",
		"js-cookie": "^3.0.5",
		"zod": "^4.1.13"
	},
	"peerDependencies": {
		"next": "^16.0.0",
		"react": "^19.0.0"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/js-cookie": "^3.0.6",
		"@types/node": "^20.19.39",
		"@types/react": "^19.2.14",
		"next": "16.0.8",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3"
	}
}
